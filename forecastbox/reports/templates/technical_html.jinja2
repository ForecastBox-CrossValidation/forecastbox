<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ metadata.title | default('Technical Forecast Report') }}</title>
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body {
            font-family: 'Consolas', 'Courier New', monospace;
            max-width: 1200px;
            margin: 0 auto;
            padding: 30px;
            background: #f5f5f5;
            color: #2d2d2d;
            line-height: 1.6;
            font-size: 14px;
        }
        header {
            background: #1B3A5C;
            color: white;
            padding: 25px;
            margin: -30px -30px 30px -30px;
        }
        h1 { font-size: 1.8em; margin-bottom: 5px; }
        h2 {
            color: #1B3A5C;
            margin-top: 30px;
            margin-bottom: 12px;
            padding: 8px;
            background: #e8f4f8;
            border-left: 4px solid #2E86AB;
        }
        h3 { color: #2E86AB; margin-top: 15px; margin-bottom: 8px; }
        .meta { color: #aaa; font-size: 0.85em; }
        p { margin-bottom: 10px; }
        table {
            border-collapse: collapse;
            width: 100%;
            margin: 10px 0;
            font-size: 0.9em;
        }
        th, td {
            padding: 8px 12px;
            text-align: left;
            border: 1px solid #ccc;
        }
        th { background: #1B3A5C; color: white; font-size: 0.85em; }
        tr:nth-child(even) { background: #f0f0f0; }
        code {
            background: #e0e0e0;
            padding: 2px 6px;
            border-radius: 3px;
            font-size: 0.9em;
        }
        pre {
            background: #2d2d2d;
            color: #f0f0f0;
            padding: 15px;
            border-radius: 4px;
            overflow-x: auto;
            margin: 10px 0;
        }
        .plot-container {
            text-align: center;
            margin: 15px 0;
            background: white;
            padding: 10px;
            border: 1px solid #ddd;
        }
        .plot-container img { max-width: 100%; height: auto; }
        .metrics-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
            gap: 10px;
            margin: 15px 0;
        }
        .metric-card {
            background: white;
            border: 1px solid #ccc;
            padding: 12px;
            text-align: center;
        }
        .metric-card .value { font-size: 1.5em; font-weight: bold; color: #1B3A5C; }
        .metric-card .label { font-size: 0.75em; color: #666; }
        .section { margin-bottom: 25px; }
        .formula {
            background: #fff;
            border: 1px solid #ddd;
            padding: 15px;
            margin: 10px 0;
            text-align: center;
            font-style: italic;
        }
        footer {
            margin-top: 30px;
            padding-top: 10px;
            border-top: 1px solid #ddd;
            color: #999;
            font-size: 0.8em;
            text-align: center;
        }
    </style>
</head>
<body>
    <header>
        <h1>{{ metadata.title | default('Technical Forecast Report') }}</h1>
        <div class="meta">
            {% if metadata.author %}Author: {{ metadata.author }} | {% endif %}
            Date: {{ metadata.date | default('') }} |
            Template: technical
        </div>
    </header>

    {# Render ALL sections including technical details #}
    {% for section in sections %}
    <div class="section" id="section-{{ section.type | default('unknown') }}">
        <h2>{{ section.title | default('Section') }}</h2>

        {% if section.text %}
        <p>{{ section.text }}</p>
        {% endif %}

        {# Summary #}
        {% if section.type == 'summary' and section.key_metrics %}
        <div class="metrics-grid">
            {% for name, value in section.key_metrics.items() %}
            <div class="metric-card">
                <div class="value">{{ "%.6f" | format(value) }}</div>
                <div class="label">{{ name | upper }}</div>
            </div>
            {% endfor %}
        </div>
        {% endif %}

        {# Data #}
        {% if section.type == 'data' %}
        <table>
            <tr><th>Property</th><th>Value</th></tr>
            <tr><td>Observations</td><td>{{ section.data_length | default('N/A') }}</td></tr>
            <tr><td>Horizon</td><td>{{ section.horizon | default('N/A') }}</td></tr>
            {% if section.preprocess %}
            <tr><td>Preprocessing Pipeline</td><td><code>{{ section.preprocess | join(' -> ') }}</code></td></tr>
            {% endif %}
        </table>
        {% endif %}

        {# Models with metadata #}
        {% if section.type == 'models' and section.models %}
        <table>
            <tr><th>Model</th><th>Horizon</th><th>Intervals</th><th>Metadata</th></tr>
            {% for model in section.models %}
            <tr>
                <td><strong>{{ model.name }}</strong></td>
                <td>{{ model.horizon }}</td>
                <td>{{ 'Yes' if model.has_intervals else 'No' }}</td>
                <td><code>{{ model.metadata | default({}) }}</code></td>
            </tr>
            {% endfor %}
        </table>
        {% endif %}

        {# Forecasts with plot #}
        {% if section.type == 'forecasts' and section.plot_base64 %}
        <div class="plot-container">
            <img src="data:image/png;base64,{{ section.plot_base64 }}" alt="Forecast">
        </div>
        {% endif %}

        {# Evaluation with full detail #}
        {% if section.type == 'evaluation' and section.evaluation %}
        <table>
            <tr>
                <th>Model</th>
                {% for col in section.evaluation.keys() %}
                <th>{{ col | upper }}</th>
                {% endfor %}
            </tr>
            {% if section.evaluation %}
            {% set first_col = section.evaluation.keys() | list | first %}
            {% if section.evaluation[first_col] is mapping %}
            {% for row in section.evaluation[first_col].keys() %}
            <tr>
                <td>{{ row }}</td>
                {% for col in section.evaluation.keys() %}
                <td>
                    {% if section.evaluation[col][row] is number %}
                    {{ "%.6f" | format(section.evaluation[col][row]) }}
                    {% else %}
                    {{ section.evaluation[col][row] }}
                    {% endif %}
                </td>
                {% endfor %}
            </tr>
            {% endfor %}
            {% endif %}
            {% endif %}
        </table>

        {# Technical formulas #}
        <h3>Metric Definitions</h3>
        <div class="formula">
            RMSE = sqrt(1/n * sum((y_t - y_hat_t)^2))
        </div>
        <div class="formula">
            MAE = 1/n * sum(|y_t - y_hat_t|)
        </div>
        <div class="formula">
            MAPE = 100/n * sum(|y_t - y_hat_t| / |y_t|)
        </div>
        {% endif %}

        {# Combination with weights #}
        {% if section.type == 'combination' and section.weights %}
        <p>Method: <code>{{ section.method | default('N/A') }}</code></p>
        <table>
            <tr><th>Model</th><th>Weight</th></tr>
            {% for name, weight in section.weights.items() %}
            <tr><td>{{ name }}</td><td>{{ "%.6f" | format(weight) }}</td></tr>
            {% endfor %}
        </table>
        {% endif %}

        {# Diagnostics with detail #}
        {% if section.type == 'diagnostics' and section.diagnostics %}
        {% for model_name, diag in section.diagnostics.items() %}
        <h3>{{ model_name }}</h3>
        <table>
            <tr><th>Statistic</th><th>Value</th></tr>
            {% for stat, value in diag.items() %}
            <tr><td>{{ stat }}</td><td>{{ "%.6f" | format(value) }}</td></tr>
            {% endfor %}
        </table>
        {% endfor %}
        {% endif %}

        {# Appendix with timing and metadata #}
        {% if section.type == 'appendix' %}
        {% if section.execution_time %}
        <h3>Execution Time</h3>
        <table>
            <tr><th>Step</th><th>Time (s)</th></tr>
            {% for step, time in section.execution_time.items() %}
            <tr><td>{{ step }}</td><td>{{ "%.6f" | format(time) }}</td></tr>
            {% endfor %}
        </table>
        {% endif %}

        {% if section.metadata %}
        <h3>Pipeline Configuration</h3>
        <pre>{{ section.metadata }}</pre>
        {% endif %}
        {% endif %}

    </div>
    {% endfor %}

    <footer>
        Generated by forecastbox (technical template) | {{ metadata.date | default('') }}
    </footer>
</body>
</html>
