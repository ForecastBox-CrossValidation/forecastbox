<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ metadata.title | default('Executive Forecast Report') }}</title>
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body {
            font-family: 'Georgia', 'Times New Roman', serif;
            max-width: 900px;
            margin: 0 auto;
            padding: 50px;
            background: #fff;
            color: #333;
            line-height: 1.8;
        }
        header {
            text-align: center;
            border-bottom: 2px solid #1B3A5C;
            padding-bottom: 25px;
            margin-bottom: 40px;
        }
        h1 { color: #1B3A5C; font-size: 2.2em; margin-bottom: 10px; }
        h2 {
            color: #1B3A5C;
            margin-top: 40px;
            margin-bottom: 20px;
            font-size: 1.4em;
        }
        .meta { color: #888; font-size: 0.9em; }
        p { margin-bottom: 15px; font-size: 1.05em; }
        .highlight-box {
            background: #f0f7fa;
            border-left: 4px solid #2E86AB;
            padding: 20px;
            margin: 20px 0;
            border-radius: 0 8px 8px 0;
        }
        .highlight-box .value {
            font-size: 2em;
            font-weight: bold;
            color: #1B3A5C;
        }
        .highlight-box .label {
            color: #666;
            font-size: 0.9em;
        }
        .key-metrics {
            display: flex;
            justify-content: space-around;
            flex-wrap: wrap;
            margin: 25px 0;
        }
        .key-metric {
            text-align: center;
            padding: 15px;
        }
        .key-metric .value {
            font-size: 1.8em;
            font-weight: bold;
            color: #1B3A5C;
        }
        .key-metric .label {
            font-size: 0.85em;
            color: #666;
        }
        .plot-container {
            text-align: center;
            margin: 25px 0;
        }
        .plot-container img {
            max-width: 100%;
            height: auto;
            border-radius: 4px;
        }
        table {
            border-collapse: collapse;
            width: 100%;
            margin: 15px 0;
        }
        th, td {
            padding: 10px 15px;
            text-align: left;
            border-bottom: 1px solid #eee;
        }
        th { color: #1B3A5C; font-weight: 600; border-bottom: 2px solid #1B3A5C; }
        footer {
            margin-top: 50px;
            padding-top: 15px;
            border-top: 1px solid #ddd;
            color: #bbb;
            font-size: 0.8em;
            text-align: center;
        }
    </style>
</head>
<body>
    <header>
        <h1>{{ metadata.title | default('Executive Forecast Report') }}</h1>
        <div class="meta">
            {% if metadata.author %}{{ metadata.author }} | {% endif %}
            {{ metadata.date | default('') }}
        </div>
    </header>

    {# Only render summary, forecasts, and scenarios for executive template #}
    {% for section in sections %}
    {% if section.type in ['summary', 'forecasts', 'scenarios'] %}

    <h2>{{ section.title | default('Section') }}</h2>

    {% if section.text %}
    <p>{{ section.text }}</p>
    {% endif %}

    {% if section.type == 'summary' and section.key_metrics %}
    <div class="key-metrics">
        {% for name, value in section.key_metrics.items() %}
        <div class="key-metric">
            <div class="value">{{ "%.4f" | format(value) }}</div>
            <div class="label">{{ name | upper }}</div>
        </div>
        {% endfor %}
    </div>
    {% if section.best_model %}
    <div class="highlight-box">
        <div class="label">Recommended Model</div>
        <div class="value">{{ section.best_model }}</div>
    </div>
    {% endif %}
    {% endif %}

    {% if section.type == 'forecasts' and section.plot_base64 %}
    <div class="plot-container">
        <img src="data:image/png;base64,{{ section.plot_base64 }}" alt="Forecast">
    </div>
    {% endif %}

    {% endif %}
    {% endfor %}

    <footer>
        Generated by forecastbox | {{ metadata.date | default('') }}
    </footer>
</body>
</html>
